<Window x:Class="RTMPProjector.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RTMP Projector — Update"
        Width="520" Height="420"
        MinWidth="520" MinHeight="420"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeep}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>
        <Style x:Key="ChipText" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="32">

        <!-- ══ SCREEN: available ══════════════════════════════════════ -->
        <StackPanel x:Name="ScreenAvailable" Visibility="Collapsed">
            <TextBlock Text="Update Available" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrim}" Margin="0,0,0,6"/>
            <TextBlock Text="A new version of RTMP Projector is ready to download."
                       Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,20"/>

            <!-- Version chips -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Style="{StaticResource Chip}" Background="{StaticResource BgInput}">
                    <TextBlock x:Name="ChipCurrent" Style="{StaticResource ChipText}"
                               Foreground="{StaticResource TextMuted}"/>
                </Border>
                <TextBlock Text="→" Foreground="{StaticResource TextMuted}" FontSize="16"
                           VerticalAlignment="Center" Margin="12,0"/>
                <Border Style="{StaticResource Chip}" Background="{StaticResource Accent}">
                    <TextBlock x:Name="ChipNew" Style="{StaticResource ChipText}"
                               Foreground="White"/>
                </Border>
                <TextBlock x:Name="SizeLabel" Foreground="{StaticResource TextMuted}"
                           FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <!-- Release notes -->
            <Border Background="{StaticResource BgCard}" CornerRadius="6"
                    Padding="12" Height="140" Margin="0,0,0,24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotes" Foreground="{StaticResource TextMuted}"
                               FontSize="12" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnDownload" Style="{StaticResource BaseBtn}"
                        Content="Download Now" Click="BtnDownload_Click"/>
                <Button x:Name="BtnLater" Style="{StaticResource GhostBtn}"
                        Content="Later" Margin="12,0,0,0" Click="BtnLater_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- ══ SCREEN: downloading ════════════════════════════════════ -->
        <StackPanel x:Name="ScreenDownload" Visibility="Collapsed"
                    VerticalAlignment="Center">
            <TextBlock Text="Downloading Update…" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrim}" Margin="0,0,0,24"/>

            <ProgressBar x:Name="DownloadBar" Height="8" Minimum="0" Maximum="100"
                         Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ProgressLabel" Foreground="{StaticResource TextMuted}"
                           FontSize="12"/>
                <TextBlock x:Name="SpeedLabel" Grid.Column="1"
                           Foreground="{StaticResource TextMuted}" FontSize="12"/>
            </Grid>
        </StackPanel>

        <!-- ══ SCREEN: done ═══════════════════════════════════════════ -->
        <StackPanel x:Name="ScreenDone" Visibility="Collapsed">
            <TextBlock Text="Download Complete!" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource Success}" Margin="0,0,0,8"/>
            <TextBlock Text="Follow these steps to install the update:"
                       Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,20"/>

            <Border Background="{StaticResource BgCard}" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource TextPrim}" FontSize="13" Margin="0,0,0,8">
                        <Run FontWeight="Bold" Foreground="{StaticResource Accent}">1. </Run>
                        <Run>Click "Run Installer" below — RTMP Projector will close.</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextPrim}" FontSize="13" Margin="0,0,0,8">
                        <Run FontWeight="Bold" Foreground="{StaticResource Accent}">2. </Run>
                        <Run>A PowerShell window may flash briefly — this is normal.</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextPrim}" FontSize="13" Margin="0,0,0,8">
                        <Run FontWeight="Bold" Foreground="{StaticResource Accent}">3. </Run>
                        <Run>RTMP Projector will restart automatically once updated.</Run>
                    </TextBlock>
                    <Separator Margin="0,8"/>
                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11"
                               TextWrapping="Wrap">
                        Windows may show a SmartScreen warning because the update
                        script is not code-signed. Click "More info → Run anyway" if prompted.
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnInstall" Style="{StaticResource BaseBtn}"
                        Content="Run Installer" Click="BtnInstall_Click"/>
                <Button Style="{StaticResource GhostBtn}" Content="Not Now"
                        Margin="12,0,0,0" Click="BtnLater_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- ══ SCREEN: up to date ══════════════════════════════════════ -->
        <StackPanel x:Name="ScreenUpToDate" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="✓" FontSize="48" Foreground="{StaticResource Success}"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="You're up to date!" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrim}" HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="UpToDateVersion" Foreground="{StaticResource TextMuted}"
                       FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <Button Style="{StaticResource GhostBtn}" Content="Close"
                    HorizontalAlignment="Center" Click="BtnLater_Click"/>
        </StackPanel>

        <!-- ══ SCREEN: error ══════════════════════════════════════════ -->
        <StackPanel x:Name="ScreenError" Visibility="Collapsed"
                    VerticalAlignment="Center">
            <TextBlock Text="Update Error" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource Danger}" Margin="0,0,0,12"/>
            <Border Background="{StaticResource BgCard}" CornerRadius="6"
                    Padding="14" Margin="0,0,0,24">
                <TextBlock x:Name="ErrorMessage" Foreground="{StaticResource TextMuted}"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnRetry" Style="{StaticResource BaseBtn}"
                        Content="Retry" Click="BtnRetry_Click"/>
                <Button Style="{StaticResource GhostBtn}" Content="Close"
                        Margin="12,0,0,0" Click="BtnLater_Click"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
