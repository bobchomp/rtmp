<Application x:Class="RTMPProjector.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>

        <!-- ── Colours ─────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgDeep"     Color="#0f1117"/>
        <SolidColorBrush x:Key="BgPanel"    Color="#1a1d27"/>
        <SolidColorBrush x:Key="BgCard"     Color="#22263a"/>
        <SolidColorBrush x:Key="BgInput"    Color="#2a2f45"/>
        <SolidColorBrush x:Key="Accent"     Color="#5865f2"/>
        <SolidColorBrush x:Key="AccentHot"  Color="#4752c4"/>
        <SolidColorBrush x:Key="Success"    Color="#2ecc71"/>
        <SolidColorBrush x:Key="Danger"     Color="#e74c3c"/>
        <SolidColorBrush x:Key="TextPrim"   Color="#f0f0f8"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Border"     Color="#333655"/>

        <!-- ── Base button ──────────────────────────────────────────── -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrim}"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHot}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
        </Style>

        <!-- ── TextBox ───────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrim}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CaretBrush"   Value="{StaticResource TextPrim}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CheckBox ─────────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrim}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── ComboBox ─────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrim}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="8,5"/>
        </Style>

        <!-- ── Label ────────────────────────────────────────────────── -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="0,0,0,3"/>
        </Style>

        <!-- ── ListBox ───────────────────────────────────────────────── -->
        <Style TargetType="ListBox">
            <Setter Property="Background"     Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"     Value="{StaticResource TextPrim}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrim}"/>
            <Setter Property="Padding"    Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgInput}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TabControl ────────────────────────────────────────────── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"     Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground"     Value="{StaticResource TextMuted}"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"        Value="16,10"/>
            <Setter Property="FontSize"       Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrim}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ScrollBar ─────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
        </Style>

        <!-- ── Separator ─────────────────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Border}"/>
            <Setter Property="Margin"     Value="0,8"/>
        </Style>

    </Application.Resources>
</Application>
