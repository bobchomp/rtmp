<Window x:Class="RTMPProjector.Windows.WhatsNewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New"
        Width="520" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDeep}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleLabel" Grid.Row="0"
                   Foreground="{DynamicResource TextPrim}"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="Here's what changed in this release:"
                   Foreground="{DynamicResource TextMuted}"
                   FontSize="13" Margin="0,0,0,16"/>

        <Border Grid.Row="2"
                Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                <TextBlock x:Name="NotesText"
                           Foreground="{DynamicResource TextPrim}"
                           FontSize="13" TextWrapping="Wrap"
                           FontFamily="Consolas"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="3"
                Content="Got it"
                Style="{StaticResource BaseBtn}"
                HorizontalAlignment="Right"
                Margin="0,20,0,0"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>
