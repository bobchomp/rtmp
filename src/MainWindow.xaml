<Window x:Class="RTMPProjector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RTMPProjector.ViewModels"
        xmlns:models="clr-namespace:RTMPProjector.Models"
        Title="RTMP Projector"
        Width="760" Height="620"
        MinWidth="640" MinHeight="520"
        Background="{DynamicResource BgDeep}"
        WindowStartupLocation="Manual"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized">

    <Window.Resources>
        <!-- Card panel style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{DynamicResource BgCard}"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="16"/>
            <Setter Property="Margin"           Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════ HEADER ══════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RTMP" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"/>
                    <TextBlock Text=" Projector" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrim}"/>
                    <Border Background="{DynamicResource BgInput}" CornerRadius="4"
                            Padding="8,3" Margin="16,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding ServerStatusColor}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding ServerStatusText}"
                                       Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Server toggle + minimize + theme toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BaseBtn}"
                            Command="{Binding ToggleServerCommand}"
                            IsEnabled="{Binding IsBusy, Converter={x:Static vm:NegateBoolConverter.Instance}}">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Start Server"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                                <Setter Property="Text" Value="Stop Server"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <Button Style="{StaticResource GhostBtn}" Content="Minimise to Tray"
                            Margin="8,0,0,0" Click="MinimiseToTray_Click"/>
                    <!-- Feature 10: Theme toggle button -->
                    <Button Style="{StaticResource GhostBtn}" Margin="8,0,0,0"
                            Command="{Binding ToggleThemeCommand}" Padding="8,8" FontSize="14">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="☀"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Settings.Theme}" Value="Light">
                                                <Setter Property="Text" Value="🌙"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════ BUSY OVERLAY ══════════════════════ -->
        <Grid Grid.Row="1" Panel.ZIndex="10"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
            <Rectangle Fill="{DynamicResource BgDeep}" Opacity="0.7"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding BusyText}" Foreground="{DynamicResource TextPrim}"
                           FontSize="16" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="6" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════ TABS ══════════════════════════════ -->
        <TabControl Grid.Row="1" Background="{DynamicResource BgDeep}"
                    Margin="0" BorderThickness="0">

            <!-- ─────────── STREAM KEYS TAB ─────────── -->
            <TabItem Header="Stream Keys">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Key list -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource Card}" Padding="0" Grid.Row="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="CONFIGURED KEYS" Style="{StaticResource SectionLabel}"
                                           Margin="12,12,12,8"/>
                                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0"
                                         ItemsSource="{Binding StreamKeys}"
                                         SelectedItem="{Binding SelectedStreamKey}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Name + key -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13" Foreground="{DynamicResource TextPrim}"/>
                                                    <TextBlock Text="{Binding Key}"
                                                               FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                               FontFamily="Consolas"/>
                                                </StackPanel>

                                                <!-- Feature 3: Per-key copy button (visible on hover) -->
                                                <Button Grid.Column="1"
                                                        Content="⎘" Padding="4,2" FontSize="11"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding DataContext.CopyRtmpUrlCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostBtn}">
                                                            <Setter Property="Opacity" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <Binding Path="IsMouseOver"
                                                                                 RelativeSource="{RelativeSource AncestorType=ListBoxItem}"/>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Feature 4: REC badge -->
                                                <TextBlock Grid.Column="2" Text="● REC"
                                                           Foreground="{DynamicResource Danger}"
                                                           FontSize="9" FontWeight="Bold"
                                                           VerticalAlignment="Center" Margin="4,0,2,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Feature 2: Health-colored indicator dot -->
                                                <Ellipse Grid.Column="3" Width="8" Height="8"
                                                         VerticalAlignment="Center" Margin="4,0,2,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HealthState}"
                                                                             Value="{x:Static models:StreamHealthState.Good}">
                                                                    <Setter Property="Fill" Value="{DynamicResource Success}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthState}"
                                                                             Value="{x:Static models:StreamHealthState.Degraded}">
                                                                    <Setter Property="Fill" Value="#f39c12"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthState}"
                                                                             Value="{x:Static models:StreamHealthState.Poor}">
                                                                    <Setter Property="Fill" Value="{DynamicResource Danger}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthState}"
                                                                             Value="{x:Static models:StreamHealthState.Offline}">
                                                                    <Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BaseBtn}" Content="+ Add Key"
                                    Command="{Binding AddStreamKeyCommand}" HorizontalAlignment="Stretch"
                                    Width="118"/>
                            <Button Style="{StaticResource DangerBtn}" Content="Remove" Margin="8,0,0,0"
                                    Command="{Binding RemoveStreamKeyCommand}"
                                    CommandParameter="{Binding SelectedStreamKey}"
                                    Width="118"/>
                        </StackPanel>
                    </Grid>

                    <!-- Key detail editor -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <!-- No selection placeholder -->
                            <TextBlock Text="Select a stream key to configure it."
                                       Foreground="{DynamicResource TextMuted}" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedStreamKey}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Editor form -->
                            <StackPanel DataContext="{Binding SelectedStreamKey}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="KEY DETAILS" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Display Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                                <TextBlock Text="Stream Key (auto-generated)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" FontSize="12"
                                         IsReadOnly="True" Background="{DynamicResource BgDeep}"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="RTMP URL — give this to your encoder"
                                           Style="{StaticResource SectionLabel}" Margin="0,4,0,6"/>
                                <Border Background="{DynamicResource BgDeep}" CornerRadius="5"
                                        BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                                        Padding="10,8" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Consolas" FontSize="13"
                                                   Foreground="{DynamicResource Accent}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="rtmp://{0}:{1}/live/{2}">
                                                    <Binding Path="DataContext.LocalIpAddress"
                                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    <Binding Path="DataContext.Settings.RtmpPort"
                                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    <Binding Path="Key"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Button Grid.Column="1" Style="{StaticResource GhostBtn}"
                                                Content="Copy" Margin="12,0,0,0"
                                                Command="{Binding DataContext.CopyRtmpUrlCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>

                                <Button Style="{StaticResource BaseBtn}" Content="▶  Open Projection Window"
                                        Margin="0,4,0,0"
                                        Command="{Binding DataContext.OpenProjectionCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Left"/>

                                <Separator/>

                                <TextBlock Text="RECORDING" Style="{StaticResource SectionLabel}" Margin="0,4,0,6"/>
                                <CheckBox Content="Record this stream" IsChecked="{Binding RecordEnabled}" Margin="0,0,0,8"/>
                                <Button HorizontalAlignment="Left" Margin="0,0,0,12"
                                        Command="{Binding DataContext.ToggleRecordingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding DataContext.SelectedStreamKey, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource BaseBtn}">
                                            <Setter Property="Content" Value="● Start Recording"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.SelectedStreamKey.RecordEnabled,
                                                    RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Content" Value="■ Stop Recording"/>
                                                    <Setter Property="Background" Value="{DynamicResource Danger}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Separator/>

                                <TextBlock Text="RESTREAM / FORWARD" Style="{StaticResource SectionLabel}" Margin="0,4,0,6"/>
                                <CheckBox Content="Forward to another RTMP endpoint" IsChecked="{Binding RestreamEnabled}" Margin="0,0,0,8"/>
                                <TextBlock Text="Destination URL" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding RestreamUrl, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding RestreamEnabled}"
                                         FontFamily="Consolas" FontSize="12"
                                         Margin="0,0,0,4"/>
                                <TextBlock Text="e.g. rtmp://live.twitch.tv/app/YOUR_KEY"
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"/>

                                <Separator Margin="0,12"/>

                                <Button Style="{StaticResource BaseBtn}" Content="Save Changes"
                                        Command="{Binding DataContext.SaveSettingsCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─────────── DISPLAY TAB ─────────── -->
            <TabItem Header="Display">
                <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="520">

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="PROJECTION MONITOR" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="Choose which monitor incoming streams are projected fullscreen on."
                                           Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>
                                <ComboBox ItemsSource="{Binding Monitors}"
                                          SelectedItem="{Binding SelectedMonitor}"
                                          DisplayMemberPath="DisplayName"/>

                                <Separator Margin="0,16"/>

                                <CheckBox Content="Automatically project when a stream connects"
                                          IsChecked="{Binding Settings.AutoProjectOnConnect}"
                                          Margin="0,0,0,8"/>

                                <TextBlock Text="Tip: You can also manually open a projection window by right-clicking a live stream key."
                                           Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="RECORDING PATH" Style="{StaticResource SectionLabel}"/>
                                <!-- Feature 5: Recording path row with Browse + Open Folder -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding Settings.RecordingPath}"
                                             FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                                             Background="{DynamicResource BgDeep}"/>
                                    <Button Grid.Column="1" Style="{StaticResource GhostBtn}"
                                            Content="Browse…" Margin="8,0,0,0"
                                            Command="{Binding BrowseRecordingPathCommand}"/>
                                    <Button Grid.Column="2" Style="{StaticResource GhostBtn}"
                                            Content="Open Folder" Margin="8,0,0,0"
                                            Command="{Binding OpenRecordingsFolderCommand}"/>
                                </Grid>

                                <!-- Feature 6: Disk space indicator (hidden when DiskSpaceText is empty) -->
                                <TextBlock x:Name="DiskSpaceLabel"
                                           Text="{Binding DiskSpaceText}"
                                           FontSize="12" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Success}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiskSpaceIsLow}" Value="True">
                                                    <Setter Property="Foreground" Value="#f39c12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiskSpaceText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="STARTUP" Style="{StaticResource SectionLabel}"/>
                                <CheckBox Content="Start minimised to system tray"
                                          IsChecked="{Binding Settings.StartMinimized}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="Automatically start the RTMP server on launch"
                                          IsChecked="{Binding Settings.AutoStartServer}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="Auto-start with Windows (minimised to tray)"
                                          IsChecked="{Binding Settings.AutoStartWithWindows}"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource BaseBtn}" Content="Save Settings"
                                    Command="{Binding SaveSettingsCommand}"/>
                            <Button Style="{StaticResource GhostBtn}" Content="▶  Open Projection Window"
                                    Margin="12,0,0,0"
                                    Command="{Binding OpenProjectionCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ─────────── SERVER TAB ─────────── -->

            <TabItem Header="Server">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Settings area -->
                    <StackPanel Grid.Row="0" MaxWidth="520" HorizontalAlignment="Left">

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="RTMP SERVER" Style="{StaticResource SectionLabel}"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RTMP Port" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding Settings.RtmpPort, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="API Port (internal)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding Settings.ApiPort, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap">
                                    Publishers connect with:<LineBreak/>
                                    <Run FontFamily="Consolas" FontSize="12"
                                         Foreground="{DynamicResource Accent}">rtmp://&lt;your-ip&gt;:1935/live/&lt;stream-key&gt;</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Style="{StaticResource BaseBtn}" Content="Save Settings"
                                    Command="{Binding SaveSettingsCommand}"/>
                            <Button Style="{StaticResource GhostBtn}" Content="Check for Updates"
                                    Margin="12,0,0,0" Click="CheckForUpdates_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Diagnostics log -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="12,10,12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="DIAGNOSTICS LOG" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostBtn}" Content="Copy All"
                                            Click="CopyLog_Click" Padding="8,3"/>
                                    <Button Style="{StaticResource GhostBtn}" Content="Clear"
                                            Margin="8,0,0,0" Click="ClearLog_Click" Padding="8,3"/>
                                </StackPanel>
                            </Grid>

                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0"
                                     ItemsSource="{Binding Log}"
                                     x:Name="LogList"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     FontFamily="Consolas" FontSize="11"
                                     Foreground="{DynamicResource TextMuted}"
                                     Padding="12,0,12,8">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <Setter Property="Padding" Value="0,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ══════════════════════ STATUS BAR ════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextMuted}" FontSize="12"/>
        </Border>

    </Grid>
</Window>
